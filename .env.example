# Weekly Summary (Chef Summary) — front-end environment variables (Vite)
#
# Copy this file to `.env` and fill in the values for your Supabase project.
# `.env` is git-ignored and must never be committed.
#
# SECURITY: every VITE_* value is inlined into the browser bundle and is PUBLIC.
# Only the publishable ANON key belongs in the front-end. NEVER put the
# service-role key, an OpenAI key, a webhook secret, or any privileged
# credential in a VITE_* variable — those belong only in Supabase Edge Function
# secrets (server-side).

# Supabase project URL, e.g. https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase publishable ANON key (NOT the service-role key)
VITE_SUPABASE_ANON_KEY=
